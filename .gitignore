# Dependencies
node_modules
.pnpm-store

# Build outputs
dist
.next
.turbo
out
*.tsbuildinfo

# Stale compiled files in src dirs (should only exist in dist/)
apps/*/src/**/*.js
apps/*/src/**/*.d.ts
packages/*/src/**/*.js
packages/*/src/**/*.d.ts

# Environment
.env
.env.local
.env.*.local
!.env.example

# IDE
.idea
.vscode
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Testing
coverage
e2e/.auth/
e2e/playwright-report/
e2e/test-results/

# Prisma
packages/database/prisma/*.db
packages/database/prisma/*.db-journal

# Migration data exports (may contain PII)
bronsgroen-*.json

# Uploads (user-generated content — not committed)
uploads/*
!uploads/.gitkeep
# Signature images are static assets committed to the repo
!uploads/signatures/
uploads/signatures/*
!uploads/signatures/*.png

# Docker
.docker-data

# Claude Code
.claude/worktrees/
.claire/

# Allow project documentation
!CLAUDE.md
.worktrees/

# Build artifacts next to source config (from tsc --declaration runs)
apps/*/tailwind.config.js
apps/*/tailwind.config.d.ts
apps/*/source.config.js
apps/*/source.config.d.ts
apps/*/mdx-components.js
apps/*/mdx-components.d.ts
